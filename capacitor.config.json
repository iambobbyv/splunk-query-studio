{
  "appId": "com.souriapps.splunkquerystudio",
  "appName": "Splunk Query Studio",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#020617",
      "showSpinner": false,
      "spinnerColor": "#3b82f6",
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": false,
      "splashImmersive": false
    }
  }
}
